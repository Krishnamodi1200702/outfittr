generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String         @map("password_hash")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  wardrobe     WardrobeItem[]
  trips        Trip[]

  @@map("users")
}

model WardrobeItem {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  category   String
  name       String
  colors     String[]
  seasonTags String[]     @map("season_tags")
  formality  String
  notes      String?
  imageUrl   String?      @map("image_url")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems OutfitItem[]

  @@map("wardrobe_items")
}

model Trip {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  name       String
  location   String
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  activities String[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  days TripDay[]

  @@map("trips")
}

model TripDay {
  id               String    @id @default(cuid())
  tripId           String    @map("trip_id")
  date             DateTime
  weatherHigh      Float?    @map("weather_high")
  weatherLow       Float?    @map("weather_low")
  weatherCondition String?   @map("weather_condition")
  precipitationMm  Float?    @map("precipitation_mm")
  weatherCode      Int?      @map("weather_code")
  weatherFetchedAt DateTime? @map("weather_fetched_at")

  trip    Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  outfits Outfit[]

  @@map("trip_days")
}

model Outfit {
  id        String  @id @default(cuid())
  tripDayId String  @map("trip_day_id")
  occasion  String
  notes     String?

  tripDay TripDay      @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  items   OutfitItem[]

  @@map("outfits")
}

model OutfitItem {
  id             String @id @default(cuid())
  outfitId       String @map("outfit_id")
  wardrobeItemId String @map("wardrobe_item_id")

  outfit       Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@unique([outfitId, wardrobeItemId])
  @@map("outfit_items")
}
