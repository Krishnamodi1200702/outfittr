# ── Outfittr API — Environment Variables ──────────────
# Copy this file to .env and fill in the values.
# This file is committed to git; .env is NOT (it's in .gitignore).

# ── Database ──────────────────────────────────────────
# Local:      Uses the Docker Compose Postgres container.
# Production: Use a Neon pooled connection string (https://neon.tech).
#             Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://outfittr:outfittr_local@localhost:5432/outfittr?schema=public"

# ── Auth ──────────────────────────────────────────────
# Local:      Any string works for development.
# Production: MUST be a strong random string (64+ chars).
#             Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-random-64-char-string-in-production"

# Token expiry duration (default: 7 days).
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────
# Local:      Defaults to 4000.
# Production: Render provides PORT automatically — do NOT set it on Render.
PORT=4000

# ── CORS ──────────────────────────────────────────────
# Local:      The Next.js dev server URL.
# Production: Your exact Vercel domain — no trailing slash!
#             Correct:  https://outfittr.vercel.app
#             Wrong:    https://outfittr.vercel.app/
CORS_ORIGIN="http://localhost:3000"

# ── Environment ───────────────────────────────────────
# Local:      "development" enables verbose Prisma logging.
# Production: "production"
NODE_ENV="development"
